# Alpaca Paper Trading API Keys
# Get yours at: https://app.alpaca.markets/paper/dashboard/overview
DAYTRADING_ALPACA_API_KEY=your_api_key_here
DAYTRADING_ALPACA_SECRET_KEY=your_secret_key_here
DAYTRADING_ALPACA_PAPER=true
DAYTRADING_ALPACA_FEED=sip

# Capital & risk
DAYTRADING_INITIAL_CASH=25000
DAYTRADING_MAX_POSITIONS=3
DAYTRADING_MAX_POSITION_SHARES=1000
DAYTRADING_MAX_ORDER_SHARES=500

# Price range (focus on $1-$20 stocks)
DAYTRADING_MIN_PRICE=1.0
DAYTRADING_MAX_PRICE=20.0

# After-hours (4:00 PM–8:00 PM ET): scanning + entries for paper testing
# Set false for production (entries stop 3:30 PM ET, flatten at 3:30 PM)
DAYTRADING_AFTER_HOURS_ENABLED=false

# Network tuning (server: faster; local Mac: increase delays)
DAYTRADING_BAR_FETCH_BATCH_SIZE=10
DAYTRADING_BAR_FETCH_BATCH_DELAY_SEC=1.0
DAYTRADING_HOD_HYDRATE_BATCH_MAX=25
DAYTRADING_HOD_SEED_BATCH_SIZE=10
DAYTRADING_HOD_SEED_MAX_PER_MINUTE=100

# Scanner pool settings
DAYTRADING_HOD_MOMENTUM_BAR_POOL_MAX=250
DAYTRADING_HOD_POOL_REFRESH_MINUTES=5
DAYTRADING_MAX_WATCHLIST_SYMBOLS=50
DAYTRADING_CANDIDATE_HYDRATE_QUEUE_MAX=500
DAYTRADING_CANDIDATE_HYDRATE_BATCH_MAX=10
DAYTRADING_FAST_SCAN_PROCESS_MAX=80

# Journal retention / size controls
# Candle snapshots are large; keep off in live unless debugging a specific setup.
DAYTRADING_JOURNAL_CANDLE_SNAPSHOTS=false
DAYTRADING_JOURNAL_RETENTION_DAYS=2
DAYTRADING_JOURNAL_PRUNE_ON_START=false
DAYTRADING_JOURNAL_DAILY_PRUNE_ENABLED=true
DAYTRADING_JOURNAL_ASYNC_PRUNE=true
DAYTRADING_JOURNAL_VACUUM_ON_PRUNE=false
DAYTRADING_JOURNAL_SKIP_EVENT_TYPES=classification,market_regime

# Scalping parameters (cents)
DAYTRADING_SCALP_MOMENTUM_TARGET_CENTS=5.0
DAYTRADING_SCALP_MOMENTUM_STOP_CENTS=3.0
DAYTRADING_SCALP_MOMENTUM_TRAIL_CENTS=2.0
DAYTRADING_SCALP_MOMENTUM_SIZE=500
