# Alpaca Paper Trading API Keys
# Get yours at: https://app.alpaca.markets/paper/dashboard/overview
DAYTRADING_ALPACA_API_KEY=your_api_key_here
DAYTRADING_ALPACA_SECRET_KEY=your_secret_key_here
DAYTRADING_ALPACA_PAPER=true
DAYTRADING_ALPACA_FEED=sip

# Capital & risk
DAYTRADING_INITIAL_CASH=25000
DAYTRADING_MAX_POSITIONS=3
DAYTRADING_MAX_POSITION_SHARES=1000
DAYTRADING_MAX_ORDER_SHARES=500

# Price range (focus on $1-$20 stocks)
DAYTRADING_MIN_PRICE=1.0
DAYTRADING_MAX_PRICE=20.0

# After-hours (4:00 PM–8:00 PM ET): scanning + entries for paper testing
# Set false for production (entries stop 3:30 PM ET, flatten at 3:30 PM)
DAYTRADING_AFTER_HOURS_ENABLED=false

# Tick-based early entry: release a queued setup off live ticks (not just a
# 10s bar) when price holds within X% of the anchor, so fast movers are caught
# near the base. Anti-chase guard still applies. Default off — A/B before enabling.
DAYTRADING_TICK_ENTRY_ENABLED=false
DAYTRADING_TICK_ENTRY_CONFIRM_COUNT=2
DAYTRADING_TICK_ENTRY_MAX_ABOVE_ANCHOR=0.02

# Entry guard low-float thesis. Known floats above this cap are rejected on
# every entry path; set 0 to disable the hard known-float gate.
DAYTRADING_ENTRY_MAX_FLOAT_SHARES=20000000

# Missed A+ anti-chase memory: if an A+ setup was blocked early, do not buy
# the same move much higher for this window. Tune from entry_chase_guard rows.
DAYTRADING_MISSED_A_PLUS_CHASE_WINDOW_SEC=1800
DAYTRADING_MISSED_A_PLUS_CHASE_PCT_SUB5=0.035
DAYTRADING_MISSED_A_PLUS_CHASE_PCT_5PLUS=0.025

# Fresh-base reset for the anti-chase MEMORY (default OFF). When the current
# setup's own base has migrated >= _PCT above a stale blocked level, treat that
# level as stale (a new higher base formed) so the memory doesn't veto an entry
# the primary own-base chase guard already approves. Conservative by design — it
# only skips clearly-stale levels, so a re-entry near a recently-blocked base is
# still treated as a chase. Paper-testable; validate before enabling.
DAYTRADING_MISSED_A_PLUS_FRESH_BASE_RESET=false
DAYTRADING_MISSED_A_PLUS_FRESH_BASE_PCT=0.08

# Normal anti-chase cap: max % a fill may sit above the setup base before the
# entry is rejected as a "late chase". Cheap fast movers (price < tier) get more
# room because they cover ground between signal and fill; pricier names stay
# tight. Loosened from the old hardcoded 0.025/0.035 ($5 tier) so sub-$10 runners
# are not always rejected on the first move off the base.
DAYTRADING_ENTRY_CHASE_PCT_LOW=0.05
DAYTRADING_ENTRY_CHASE_PCT_HIGH=0.025
DAYTRADING_ENTRY_CHASE_PRICE_TIER=10.0

# Runner back-half trail (post-partial), for confirmed runner candidates. A
# wider trail rides continuation runners further (CUPR: 3%->+$49, 8%->+$179)
# but gives back more on top-and-fade names (EDHL: 3%->+$32, 8%->+$2). No flat
# value wins both; default stays tight. Raise to ride big runners harder.
DAYTRADING_RUNNER_TRAIL_PCT=0.03
DAYTRADING_RUNNER_MIN_CONFIRM_PCT=0.018

# Adaptive runner trail: scale trail width to the name's own recent 1m volatility
# so wide-swinging runners breathe (CUPR ~2.7% bars) while smooth names trail
# tight (EDHL ~1.4% bars). trail = clamp(atr_mult * median bar range, _PCT floor,
# _CAP). OFF by default: backtests showed it behaves like a flat 8% trail and
# gives back the back-half on fade/chop names (EDHL, SUNE). Volatility widens the
# trail near tops, where continuation and fade look identical — wrong signal.
# Needs a structure-aware formula + multi-symbol validation before enabling.
DAYTRADING_RUNNER_TRAIL_ADAPTIVE=false
DAYTRADING_RUNNER_TRAIL_ATR_MULT=2.5
DAYTRADING_RUNNER_TRAIL_CAP=0.10
# After first partial, runner candidates keep the original structural stop
# instead of moving the back-half to breakeven. Experimental: gives AIIO/CUPR
# style runners room, but increases give-back when the move fails.
DAYTRADING_RUNNER_GIVE_ROOM_AFTER_PARTIAL=false

# Keep hot-watch names alive while they are basing near HOD on active volume.
# This prevents smooth names from expiring during the consolidation that creates
# the actual entry setup.
DAYTRADING_HOT_WATCH_SETUP_REFRESH_ENABLED=true
DAYTRADING_HOT_WATCH_SETUP_REFRESH_MAX_PULLBACK_PCT=4.0
DAYTRADING_HOT_WATCH_SETUP_REFRESH_MIN_RECENT_VOLUME=100000

# Deep-pullback tolerance: max % below HOD a late pullback may sit before the
# verifier rejects it. vwap_pullback loosened 8->12 (was missing reclaim
# runners like DTSS/KMRK); other patterns stay at 10.
DAYTRADING_LATE_PULLBACK_MAX_HOD_PCT=12.0
DAYTRADING_LATE_PULLBACK_MAX_HOD_OTHER_PCT=10.0

# EXPERIMENTAL momentum-breakout mode (default OFF). Lets the fast breakout
# scalp fire on a high-absolute-volume breakout whose relative volume faded
# from an earlier peak. Turn ON only to paper-test; watch the scorecard for
# whether breakout pops net positive before trusting it.
DAYTRADING_MOMENTUM_BREAKOUT_ENABLED=false
DAYTRADING_MOMENTUM_BREAKOUT_MIN_RVOL=0.4
DAYTRADING_MOMENTUM_BREAKOUT_MIN_DAY_VOLUME=5000000
# Only fire on smooth tape (median per-bar range) so a tight stop holds — skips
# the violent gappy breakouts where the stop slips and the edge dies.
DAYTRADING_MOMENTUM_BREAKOUT_MAX_BAR_RANGE_PCT=3.0
# Catch the early breakout/reclaim that scores just under the 80 gate (smooth +
# high-volume only), down to this floor.
DAYTRADING_MOMENTUM_BREAKOUT_SCORE_FLOOR=72.0

# EXPERIMENTAL momentum-burst LIVE (default OFF). Promotes the momentum_burst
# scanner from watch-only to a live A+ entry (was backtest-only). This is the
# flag that turned SUNE's first entry from +$10 to +$19 in backtest. Adds losers
# on the basket — paper-test the scorecard by_entry_mode line before trusting it.
DAYTRADING_MOMENTUM_BURST_LIVE_ENABLED=false

# EXPERIMENTAL elite-wide-spread scout. When unset, this is enabled only in
# paper mode (DAYTRADING_ALPACA_PAPER=true) and disabled in live mode. It lets
# only top-score, liquid, near-HOD A+ runners pass up to ~1.1% spread with 0.25x
# size, tagged "elite_wide_spread" for scorecard validation.
# DAYTRADING_ELITE_WIDE_SPREAD_ENABLED=true

# EXPERIMENTAL conservative fresh-VWAP-reclaim scout (default OFF). After a dump
# candle, allows a reduced-size scout only when a fresh green base rebuilt above
# VWAP on rising volume + low float (the DSY case). Failed/below-VWAP reclaims
# (the GMM case) stay rejected. Tagged "fresh_vwap_reclaim_scout" — paper-test
# its by_entry_mode line on the scorecard before trusting it.
DAYTRADING_FRESH_VWAP_RECLAIM_SCOUT_ENABLED=false
DAYTRADING_FRESH_VWAP_RECLAIM_SCOUT_MAX_FLOAT=20000000
# EXPERIMENTAL near-miss VWAP reclaim scout. Lets A+ VWAP pullbacks that score
# 75-79/100 enter as a 0.30x scout only when reclaiming VWAP on active liquid
# tape. Tagged "vwap_reclaim_scout" for scorecard measurement.
DAYTRADING_VWAP_RECLAIM_SCOUT_ENABLED=false

# EXPERIMENTAL level-breakout scout (default OFF). Catches smooth/liquid level
# reclaims earlier than first_pullback_reclaim with reduced size and scorecard
# tag "level_breakout_scout". Backtest/paper-test before enabling.
DAYTRADING_LEVEL_BREAKOUT_SCOUT_ENABLED=false
DAYTRADING_LEVEL_BREAKOUT_SCOUT_MIN_SESSION_MOVE_PCT=3.0

# Network tuning (server: faster; local Mac: increase delays)
DAYTRADING_BAR_FETCH_BATCH_SIZE=10
DAYTRADING_BAR_FETCH_BATCH_DELAY_SEC=1.0
DAYTRADING_HOD_HYDRATE_BATCH_MAX=25
DAYTRADING_HOD_SEED_BATCH_SIZE=10
DAYTRADING_HOD_SEED_MAX_PER_MINUTE=100

# Scanner pool settings
DAYTRADING_HOD_MOMENTUM_BAR_POOL_MAX=250
DAYTRADING_HOD_POOL_REFRESH_MINUTES=5
DAYTRADING_MAX_WATCHLIST_SYMBOLS=50
DAYTRADING_CANDIDATE_HYDRATE_QUEUE_MAX=500
DAYTRADING_CANDIDATE_HYDRATE_BATCH_MAX=10
DAYTRADING_FAST_SCAN_PROCESS_MAX=80

# Journal retention / size controls
# Candle snapshots are large; keep off in live unless debugging a specific setup.
DAYTRADING_JOURNAL_CANDLE_SNAPSHOTS=false
DAYTRADING_JOURNAL_RETENTION_DAYS=2
DAYTRADING_JOURNAL_PRUNE_ON_START=false
DAYTRADING_JOURNAL_DAILY_PRUNE_ENABLED=true
DAYTRADING_JOURNAL_ASYNC_PRUNE=true
DAYTRADING_JOURNAL_VACUUM_ON_PRUNE=false
DAYTRADING_JOURNAL_SKIP_EVENT_TYPES=classification,market_regime

# Scalping parameters (cents)
DAYTRADING_SCALP_MOMENTUM_TARGET_CENTS=5.0
DAYTRADING_SCALP_MOMENTUM_STOP_CENTS=3.0
DAYTRADING_SCALP_MOMENTUM_TRAIL_CENTS=2.0
DAYTRADING_SCALP_MOMENTUM_SIZE=500
